#!/usr/bin/env bash
set -euo pipefail

# inspired by https://github.com/cjermain/pi-less-yolo/

# Wrapper script to run the pi coding agent inside a Docker container.
# Supports an optional --build flag to rebuild the image before running.

readonly PI_IMAGE='pi-yolo:latest'

function script_usage() {
    cat << EOF
Usage:
    pi [OPTIONS] [PI_ARGS...]
    pi [OPTIONS] -- [PI_ARGS...]

Options:
    -h|--help       Displays this help
    -b|--build      Rebuild the Docker image before running

Any unrecognised options and arguments are forwarded to the pi agent.
Use '--' to pass flags to pi that would otherwise conflict with this script.
EOF
}


function build_image() {
    echo "Building Docker image: ${PI_IMAGE} ..."
    docker buildx build \
        --file "${script_home}/pi.Dockerfile" \
        --tag "${PI_IMAGE}" \
        "${script_home}"
}


function parse_params() {
    local param
    while [[ $# -gt 0 ]]; do
        param="$1"
        shift
        case $param in
            -h | --help)
                script_usage
                exit 0
                ;;
            -b | --build)
                build=true
                ;;
            --)
                # Everything after -- is forwarded verbatim to pi
                pi_passthrough+=("$@")
                return
                ;;
            *)
                pi_passthrough+=("${param}")
                ;;
        esac
    done
}


function main() {
    # Resolve script home correctly even when invoked via a symlink
    script_home=$(dirname "$(realpath "$0")")

    build=false
    pi_passthrough=()

    parse_params "$@"

    if [[ "${build}" == true ]]; then
        build_image
    fi

    local docker_flags=(
        '--rm'
        '--user' "$(id -u):$(id -g)"
        '--interactive'
        '--tty'
        '--cap-drop=ALL'
        '--security-opt=no-new-privileges'
        '--ipc=none'
        '--volume' "$(pwd):$(pwd)"
        '--volume' "${HOME}/.pi/agent:/pi-agent"
        '--volume' "${HOME}/.agents/skills:/home/piuser/.agents/skills/"
        '--workdir' "$(pwd)"
        '--env' "PI_CODING_AGENT_DIR=/pi-agent"
        '--env' "TERM=${TERM:-xterm-256color}"
        '--env' "COLORTERM=${COLORTERM:-truecolor}"
        '--env' "PI_TELEMETRY=${PI_TELEMETRY:-false}"
    )

    # Forward pi-related env vars and API keys if set on the host.
    # Auth file (~/.pi/agent/auth.json) takes priority over these if present.
    local pi_env_vars=(
        PI_SKIP_VERSION_CHECK
        PI_CACHE_RETENTION
        PI_PACKAGE_DIR
        VISUAL
        EDITOR
        ANTHROPIC_API_KEY
        OPENAI_API_KEY
        GEMINI_API_KEY
        OPENCODE_API_KEY
    )
    local var
    for var in "${pi_env_vars[@]}"; do
        [[ -n "${!var:-}" ]] && docker_flags+=('--env' "${var}=${!var}")
    done

    local pi_args=(
        '--append-system-prompt'
        'You are running inside a Docker container as a non-root user. No Docker socket, sudo, or system package installation (apk requires root) is available.'
    )

    docker run "${docker_flags[@]}" "${PI_IMAGE}" "${pi_args[@]}" \
        "${pi_passthrough[@]+"${pi_passthrough[@]}"}"
}

main "$@"
